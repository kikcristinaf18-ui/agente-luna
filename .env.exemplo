# Copie este arquivo para .env e preencha com suas chaves antes de rodar o projeto.
# NUNCA faça commit do arquivo .env — ele já está no .gitignore.

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sua-chave-aqui

# ── Supabase ──────────────────────────────────────────────────────────────────
# Obtenha em: Supabase > seu projeto > Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...sua-service-key-aqui
